# Production Environment Variables for Railway Deployment

# Node Environment
NODE_ENV=production

# Display for virtual X server
DISPLAY=:99

# Railway-specific
RAILWAY_UNIVERSAL_BACKEND=true

# 2Captcha API Key for solving Cloudflare challenges
# Get your API key from: https://2captcha.com/
CAPTCHA_API_KEY=your_2captcha_api_key_here

# Optional: Enable/disable captcha solving (default: true)
ENABLE_CAPTCHA_SOLVING=true

# Optional: Browserless service (if using external browser service)
# BROWSERLESS_URL=wss://your-browserless-instance.com

# Security - CHANGE THESE IN PRODUCTION
REDIS_PASSWORD=your-secure-redis-password-here
GRAFANA_PASSWORD=your-secure-grafana-password-here
VNC_PASSWORD=your-secure-vnc-password-here

# Proxy rotation (for future implementation)
# PROXY_LIST=proxy1:port,proxy2:port,proxy3:port
# PROXY_USERNAME=username
# PROXY_PASSWORD=your-secure-proxy-password

# API endpoints for fallback tiers
# These will point to your existing Railway and Vercel backends
RAILWAY_API_URL=https://detachbackend-production.up.railway.app
VERCEL_API_URL=https://detach-backend-454ebn3bh-detach1.vercel.app

# Optional: Monitoring and logging
# SENTRY_DSN=your-sentry-dsn
# LOG_LEVEL=info