# Production Environment Configuration for VPS
NODE_ENV=production
PORT=3000

# Paths
DOWNLOADS_DIR=/opt/detach-backend/downloads
CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome

# Browser settings for VPS
HEADLESS=true
BROWSER_TIMEOUT=90000
RETRY_ATTEMPTS=2

# Performance settings
MAX_CONCURRENT_DOWNLOADS=5
RATE_LIMIT_DELAY=2000

# File serving
SERVE_STATIC_FILES=true
STATIC_FILE_CACHE=86400

# Logging
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# Security
CORS_ORIGIN=*
TRUST_PROXY=true

# Domain configuration (replace with your actual domain)
DOMAIN=your-domain.com
BASE_URL=https://your-domain.com